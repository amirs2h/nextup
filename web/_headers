# Cloudflare Pages / static hosting headers for Flutter Web
# Prevent stale PWA shell; allow long cache only for hashed assets.

/
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/flutter_bootstrap.js
  Cache-Control: no-cache

/flutter.js
  Cache-Control: no-cache

/flutter_service_worker.js
  Cache-Control: no-cache, no-store, must-revalidate

/version.json
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.json
  Cache-Control: no-cache

# Content-hashed assets produced by Flutter (e.g. main.dart.js with hash in path under assets)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/canvaskit/*
  Cache-Control: public, max-age=31536000, immutable

/icons/*
  Cache-Control: public, max-age=86400
